{
	"name": "cpp-rust-learn",
	"private": true,
	"version": "0.0.1",
	"packageManager": "bun@1.2.20",
	"type": "module",
	"scripts": {
		"dev": "bun --bun ./node_modules/vite/bin/vite.js dev",
		"build": "bun --bun ./node_modules/vite/bin/vite.js build",
		"preview": "bun --bun ./node_modules/vite/bin/vite.js preview",
		"prepare": "bun --bun ./node_modules/@sveltejs/kit/svelte-kit.js sync",
		"check": "bun run prepare && bun --bun ./node_modules/svelte-check/bin/svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bun run prepare && bun --bun ./node_modules/svelte-check/bin/svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "bun --bun ./node_modules/prettier/bin/prettier.cjs --check . && bun --bun ./node_modules/eslint/bin/eslint.js .",
		"format": "bun --bun ./node_modules/prettier/bin/prettier.cjs --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/ibm-plex-sans": "^5.2.8",
		"@fontsource-variable/roboto-slab": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.14.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@google/genai": "^2.0.1",
		"monaco-editor": "^0.55.1",
		"zod": "^4.4.3"
	}
}
